# Copy to .env when you want just recipes to load local overrides.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DATA_DIR=.app/dev
APP_DATABASE_URL=.app/dev/db/cyder-template.sqlite
# SQLite is the local default; keep one connection for the conservative local path.
# File SQLite can use a larger pool for read concurrency; writes still serialize.
APP_DATABASE_POOL_SIZE=1
# Maximum time to wait for a pooled database connection.
APP_DATABASE_ACQUIRE_TIMEOUT_MS=30000
# SQLite busy timeout used by each SQLite connection when it waits on locks.
APP_SQLITE_BUSY_TIMEOUT_MS=5000
# Snowflake worker id. Keep each running instance on a distinct value from 0 to 255.
APP_ID_WORKER_ID=1
APP_LOG_LEVEL=info
APP_PUBLIC_DIR=front/dist

# Optional YAML config file. When unset, the service uses built-in defaults
# plus APP_* environment overrides.
# APP_CONFIG_PATH=config.sample.yaml

# PostgreSQL example for local development or docker compose. These values
# are local defaults only; choose real credentials for shared environments.
# APP_DATABASE_URL=postgres://cyder_template:cyder_template_dev@127.0.0.1:5432/cyder_template
# PostgreSQL integration tests require an isolated test database and run only
# when explicitly invoked with `just test-postgres`.
# APP_TEST_POSTGRES_URL=postgres://cyder_template:cyder_template_dev@127.0.0.1:5432/cyder_template_test
POSTGRES_DB=cyder_template
POSTGRES_USER=cyder_template
POSTGRES_PASSWORD=cyder_template_dev
POSTGRES_PORT=5432
COMPOSE_APP_DATABASE_POOL_SIZE=5
